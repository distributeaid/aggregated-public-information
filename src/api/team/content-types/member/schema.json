{
  "kind": "collectionType",
  "collectionName": "members",
  "info": {
    "singularName": "member",
    "pluralName": "members",
    "displayName": "Team.Member"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "Pronouns": {
      "type": "string"
    },
    "Profile": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "homeCountry": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::geo.country"
    },
    "Bio": {
      "type": "richtext"
    },
    "Roles": {
      "type": "component",
      "component": "team.role",
      "repeatable": true,
      "required": true
    }
  }
}
