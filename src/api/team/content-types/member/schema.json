{
  "kind": "collectionType",
  "collectionName": "members",
  "info": {
    "singularName": "member",
    "pluralName": "members",
    "displayName": "Team.Member"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "pronouns": {
      "type": "string"
    },
    "profile": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "homeCountry": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::geo.country"
    },
    "bio": {
      "type": "richtext"
    },
    "roles": {
      "type": "component",
      "component": "team.role",
      "repeatable": true,
      "required": true
    }
  }
}
