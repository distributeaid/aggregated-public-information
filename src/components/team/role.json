{
  "collectionName": "components_team_roles",
  "info": {
    "displayName": "Role",
    "icon": "handHeart",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "default": "volunteer",
      "enum": ["board member", "director", "coordinator", "volunteer"]
    },
    "team": {
      "type": "customField",
      "customField": "plugin::multi-select.multi-select",
      "default": "[]",
      "options": [
        "admin",
        "operations",
        "stories",
        "tech",
        "design",
        "fundraising"
      ]
    },
    "associatedCountry": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::geo.country"
    },
    "duration": {
      "type": "component",
      "component": "time.duration",
      "repeatable": false
    }
  }
}
